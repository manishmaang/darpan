# =============================================================================
# VIGILANT.IN — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=vigilant
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql://vigilant:change_me_strong_password_here@localhost:5432/vigilant

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:change_me_redis_password_here@localhost:6379/0
REDIS_PASSWORD=change_me_redis_password_here

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# ── External APIs (optional but recommended) ──────────────────────────────────
# MCA21 API v3 key — register at https://www.mca.gov.in/content/mca/global/en/data-and-reports/company-llp-information.html
MCA21_API_KEY=

# PFMS API key (if available via NIC registration)
PFMS_API_KEY=

# ── Alert notifications ───────────────────────────────────────────────────────
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# ── Application settings ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
SCRAPER_REQUEST_DELAY=2.5
MAX_SUBSIDIARY_DEPTH=4
FUZZY_MATCH_THRESHOLD=78
MIN_ENTITY_CONFIDENCE=0.50
