# =============================================================================
# DARPAN.IN — .gitignore
# =============================================================================

# ── Environment & Secrets (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.key
*.pem
*.cert
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
venv/
.venv/
env/
ENV/
.python-version

# ── pytest / testing ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Scraped data & downloads (can be regenerated) ────────────────────────────
data/
downloads/
pdfs/
*.pdf
scrape_cache/
*.sqlite
*.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
airflow/logs/
airflow/*.db
airflow/*.cfg
airflow/*.pid

# ── Node / React (if you add a proper frontend build) ─────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
frontend/build/
frontend/dist/
frontend/.env

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore override files with secrets
docker-compose.override.yml
docker-compose.prod.yml

# ── Database dumps (may contain PII) ─────────────────────────────────────────
*.sql.gz
*.dump
backups/
pg_backups/

# ── ML models (large binary files) ───────────────────────────────────────────
*.pkl
*.joblib
*.model
models/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter (if used for analysis) ───────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
vigilant-in-original.jsx

# ── Airflow (generated files) ─────────────────────────────────────────────────
airflow/airflow.db
airflow/webserver_config.py
airflow/standalone_admin_password.txt